{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "content": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss",
          "skipTests": true
        },
        "@schematics/angular:class": {
          "skipTests": true
        },
        "@schematics/angular:directive": {
          "skipTests": true
        },
        "@schematics/angular:guard": {
          "skipTests": true
        },
        "@schematics/angular:interceptor": {
          "skipTests": true
        },
        "@schematics/angular:pipe": {
          "skipTests": true
        },
        "@schematics/angular:resolver": {
          "skipTests": true
        },
        "@schematics/angular:service": {
          "skipTests": true
        }
      },
      "root": "./projects/content",
      "sourceRoot": "./projects/content/src",
      "prefix": "app-content",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": {
              "base": "./dist/content",
              "browser": ""
            },
            "browser": "./projects/content/src/main.ts",
            "tsConfig": "./projects/content/tsconfig.content.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "./projects/content/public"
              }
            ],
            "stylePreprocessorOptions": {
              "includePaths": ["public"]
            },
            "styles": [
              "./shared/styles/fonts.scss",
              "./shared/styles/theme.scss",
              "./projects/content/src/styles.scss"
            ],
            "index": "./projects/content/src/index.html"
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2MB",
                  "maximumError": "2.5MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all",
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true,
                  "inlineCritical": false
                },
                "fonts": true
              }
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "content:build:production"
            },
            "development": {
              "buildTarget": "content:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["./projects/content/src/**/*.ts", "./projects/content/src/**/*.html"]
          }
        }
      }
    },
    "popup": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss",
          "skipTests": true
        },
        "@schematics/angular:class": {
          "skipTests": true
        },
        "@schematics/angular:directive": {
          "skipTests": true
        },
        "@schematics/angular:guard": {
          "skipTests": true
        },
        "@schematics/angular:interceptor": {
          "skipTests": true
        },
        "@schematics/angular:pipe": {
          "skipTests": true
        },
        "@schematics/angular:resolver": {
          "skipTests": true
        },
        "@schematics/angular:service": {
          "skipTests": true
        }
      },
      "root": "./projects/popup",
      "sourceRoot": "./projects/popup/src",
      "prefix": "app-popup",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": {
              "base": "./dist/popup",
              "browser": ""
            },
            "browser": "./projects/popup/src/main.ts",
            "tsConfig": "./projects/popup/tsconfig.popup.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "./projects/popup/public"
              }
            ],
            "stylePreprocessorOptions": {
              "includePaths": ["public"]
            },
            "styles": ["./shared/styles/fonts.scss", "./shared/styles/theme.scss", "./projects/popup/src/styles.scss"],
            "index": "./projects/popup/src/index.html"
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2MB",
                  "maximumError": "2.5MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all",
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true,
                  "inlineCritical": false
                },
                "fonts": true
              }
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "buildTarget": "popup:build:development"
          },
          "configurations": {
            "production": {
              "buildTarget": "popup:build:production"
            },
            "development": {
              "buildTarget": "popup:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["./projects/popup/src/**/*.ts", "./projects/popup/src/**/*.html"]
          }
        }
      }
    },
    "sw": {
      "projectType": "application",
      "root": "./projects/sw",
      "sourceRoot": "./projects/sw/src",
      "architect": {
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["./projects/sw/src/**/*.ts"]
          }
        }
      }
    }
  }
}
