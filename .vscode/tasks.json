{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm watch (all projects)",
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "runOptions": {
        "instanceLimit": 1,
        "reevaluateOnRerun": true
      },
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "terminate background tasks",
      "type": "process",
      "command": "${command:workbench.action.tasks.terminate}",
      "args": [
        "npm watch (all projects)"
      ],
      "problemMatcher": []
    }
  ]
}