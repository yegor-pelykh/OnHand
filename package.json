{
  "name": "on-hand",
  "version": "3.0.0",
  "private": true,
  "author": {
    "name": "Yegor Pelykh",
    "email": "yegor.dev@gmail.com",
    "url": "https://github.com/yegor-pelykh"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "format": "prettier --write .",
    "lint:content": "ng lint content --fix",
    "lint:popup": "ng lint popup --fix",
    "lint:sw": "ng lint sw --fix",
    "lint": "npm run lint:content && npm run lint:popup && npm run lint:sw",
    "clean:dist": "rimraf dist/* --glob",
    "prepare-dist": "node prepare-dist.cjs",
    "build:content": "ng build content --configuration production",
    "build:popup": "ng build popup --configuration production",
    "build:sw": "webpack build --config ./webpack.sw.config.cjs --mode production",
    "build": "npm run clean:dist && npm run format && npm run lint && npm run build:content && npm run build:popup && npm run build:sw",
    "postbuild": "npm run prepare-dist",
    "build:dev:content": "ng build content --configuration development",
    "build:dev:popup": "ng build popup --configuration development",
    "build:dev:sw": "webpack build --config ./webpack.sw.config.cjs --mode development",
    "build:dev": "npm run clean:dist && npm run format && npm run lint && npm run build:dev:content && npm run build:dev:popup && npm run build:dev:sw",
    "postbuild:dev": "npm run prepare-dist",
    "watch:content": "ng build content --watch --configuration=development",
    "watch:popup": "ng build popup --watch --configuration=development",
    "watch:sw": "webpack build --watch --config ./webpack.sw.config.cjs --mode development",
    "watch": "npm run clean:dist && npm run format && npm run lint && concurrently \"npm run prepare-dist\" \"npm run watch:content\" \"npm run watch:popup\" \"npm run watch:sw\"",
    "pack": "node pack.cjs",
    "release": "release-it"
  },
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/cdk": "^21.2.6",
    "@angular/common": "^21.2.8",
    "@angular/compiler": "^21.2.8",
    "@angular/core": "^21.2.8",
    "@angular/forms": "^21.2.8",
    "@angular/material": "^21.2.6",
    "@angular/platform-browser": "^21.2.8",
    "@angular/router": "^21.2.8",
    "dotenv": "^17.4.1",
    "image-in-browser": "^3.5.2",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "validator": "^13.15.35"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.8",
    "@eslint/js": "^10.0.1",
    "@types/archiver": "^7.0.0",
    "@types/chrome": "^0.1.40",
    "@types/validator": "^13.15.10",
    "angular-eslint": "21.3.1",
    "archiver": "^7.0.1",
    "auto-changelog": "^2.5.0",
    "concurrently": "^9.2.1",
    "enquirer": "^2.4.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "prettier": "^3.8.2",
    "release-it": "^19.2.4",
    "rimraf": "^6.1.3",
    "ts-loader": "^9.5.7",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.58.1",
    "webpack": "^5.106.1",
    "webpack-cli": "^7.0.2"
  }
}
